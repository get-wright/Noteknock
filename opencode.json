{
  "$schema": "https://opencode.ai/config.json",
  "model": "kiro8317/gpt-5.5",
  "default_agent": "build",
  "instructions": [
    "handoff.md",
    "docs/plans/2026-06-23-noteknock-full-build.md"
  ],
  "agent": {
    "build": {
      "model": "kiro8317/gpt-5.5",
      "mode": "primary",
      "description": "Orchestrator for subagent-driven development of Noteknock. Dispatches implementer, spec-reviewer, and code-reviewer subagents per task in the plan. Reviews subagent output between tasks, stops for user approval at each phase gate."
    },
    "implementer": {
      "mode": "subagent",
      "description": "Implements one plan task; coding and tests.",
      "model": "xai/grok-composer-2.5-fast",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "spec-reviewer": {
      "mode": "subagent",
      "description": "Checks implementation against spec only.",
      "model": "kiro8317/gpt-5.5",
      "permission": {
        "edit": "deny",
        "bash": "allow"
      }
    },
    "code-reviewer": {
      "mode": "subagent",
      "description": "Code quality review after spec pass.",
      "model": "kiro8317/gpt-5.5",
      "permission": {
        "edit": "deny",
        "bash": "allow"
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "kagi": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/kagisearch/kagimcp.git@rehan/v1-api",
        "kagimcp"
      ],
      "enabled": true,
      "env": {
        "KAGI_API_KEY": "{env:KAGI_API_KEY}"
      }
    }
  }
}
